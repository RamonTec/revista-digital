---
// ============================================================
// Callout.astro — Caja de aviso/nota/advertencia
// Variantes: info, warn, success, error
// ============================================================

export interface Props {
  tipo?: 'info' | 'warn' | 'success' | 'error';
  titulo?: string;
}

const { tipo = 'info', titulo = '' } = Astro.props;

const iconos: Record<string, string> = {
  info: 'ℹ',
  warn: '⚠',
  success: '✓',
  error: '✕',
};

const labels: Record<string, string> = {
  info: 'Nota',
  warn: 'Atención',
  success: 'Correcto',
  error: 'Error',
};
---

<div class:list={['callout', `callout--${tipo}`]} data-reveal="fade">
  <div class="callout__icon">{iconos[tipo]}</div>
  <div class="callout__body">
    <span class="callout__label">{titulo || labels[tipo]}</span>
    <div class="callout__content">
      <slot />
    </div>
  </div>
</div>

<style>
  .callout {
    display: flex;
    gap: var(--sp-4);
    padding: var(--sp-4) var(--sp-5);
    margin: var(--sp-5) 0;
    border-radius: var(--r-md);
    border-left: 4px solid;
    background: var(--c-bg-secundario);
  }

  .callout__icon {
    font-size: var(--fs-lg);
    line-height: 1.5;
    flex-shrink: 0;
  }

  .callout__body {
    flex: 1;
    min-width: 0;
  }

  .callout__label {
    display: block;
    font-weight: var(--fw-semibold);
    font-size: var(--fs-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--sp-2);
  }

  .callout__content {
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
  }

  .callout__content p {
    margin-bottom: var(--sp-2);
  }

  .callout__content p:last-child {
    margin-bottom: 0;
  }

  /* === Variantes === */
  .callout--info {
    border-color: var(--c-info);
  }
  .callout--info .callout__icon,
  .callout--info .callout__label {
    color: var(--c-info);
  }

  .callout--warn {
    border-color: var(--c-warn);
  }
  .callout--warn .callout__icon,
  .callout--warn .callout__label {
    color: var(--c-warn);
  }

  .callout--success {
    border-color: var(--c-success);
  }
  .callout--success .callout__icon,
  .callout--success .callout__label {
    color: var(--c-success);
  }

  .callout--error {
    border-color: var(--c-error);
  }
  .callout--error .callout__icon,
  .callout--error .callout__label {
    color: var(--c-error);
  }
</style>