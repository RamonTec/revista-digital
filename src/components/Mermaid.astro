---
// ============================================================
// Mermaid.astro — Render de diagramas Mermaid.js
// Render bajo demanda con lazy init
// ============================================================

export interface Props {
  diagram: string;
  caption?: string;
  id?: string;
}

const { diagram, caption = '', id } = Astro.props;

const diagramId = id || `mmd-${Math.random().toString(36).slice(2, 9)}`;
// El contenido del diagrama se pasa como texto escapado
const diagramEncoded = encodeURIComponent(diagram.trim());
---

<figure class="mermaid-wrap" data-reveal>
  <div
    class="mermaid-container"
    data-mermaid={diagramId}
    data-diagram={diagramEncoded}
  >
    <div class="mermaid-loading texto-dim">Cargando diagrama…</div>
  </div>
  {caption && (
    <figcaption class="mermaid-caption texto-dim">{caption}</figcaption>
  )}
</figure>

<style>
  .mermaid-wrap {
    margin: var(--sp-6) 0;
    padding: var(--sp-5);
    background: var(--c-bg-secundario);
    border: 1px solid var(--c-borde);
    border-radius: var(--r-md);
    overflow-x: auto;
  }

  .mermaid-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 120px;
  }

  .mermaid-container svg {
    max-width: 100%;
    height: auto;
  }

  .mermaid-loading {
    font-size: var(--fs-sm);
    font-style: italic;
  }

  .mermaid-caption {
    text-align: center;
    margin-top: var(--sp-4);
    font-size: var(--fs-sm);
    font-style: italic;
  }

  /* === Scrollbar horizontal en diagramas largos === */
  .mermaid-wrap::-webkit-scrollbar {
    height: 8px;
  }

  .mermaid-wrap::-webkit-scrollbar-track {
    background: var(--c-bg-primario);
    border-radius: var(--r-full);
  }

  .mermaid-wrap::-webkit-scrollbar-thumb {
    background: var(--c-borde-activo);
    border-radius: var(--r-full);
  }
</style>

<script>
  // === Mermaid: render lazy al entrar en viewport ===
  import mermaid from 'mermaid';

  mermaid.initialize({
    startOnLoad: false,
    theme: 'dark',
    themeVariables: {
      primaryColor: '#1a2332',
      primaryTextColor: '#e6edf3',
      primaryBorderColor: '#00d9a3',
      lineColor: '#4d9eff',
      secondaryColor: '#243044',
      tertiaryColor: '#0f1419',
      background: '#1a2332',
      mainBkg: '#1a2332',
      nodeBorder: '#00d9a3',
      clusterBkg: '#0f1419',
      clusterBorder: '#2d3b4f',
      titleColor: '#00d9a3',
      edgeLabelBackground: '#1a2332',
      actorBkg: '#1a2332',
      actorBorder: '#00d9a3',
      actorTextColor: '#e6edf3',
      signalColor: '#4d9eff',
      signalTextColor: '#e6edf3',
      labelBoxBkgColor: '#243044',
      labelBoxBorderColor: '#00d9a3',
      labelTextColor: '#e6edf3',
      noteBorderColor: '#ffa657',
      noteBkgColor: '#243044',
      noteTextColor: '#e6edf3',
      activationBorderColor: '#00d9a3',
      sequenceNumberColor: '#0f1419',
    },
    flowchart: {
      curve: 'basis',
      padding: 20,
    },
    er: {
      diagramPadding: 20,
      entityPadding: 15,
      useMaxWidth: true,
    },
    securityLevel: 'loose',
  });

  async function renderMermaid(container: HTMLElement) {
    const id = container.dataset.mermaid;
    const encoded = container.dataset.diagram || '';
    if (!id || !encoded) return;

    const diagram = decodeURIComponent(encoded);

    try {
      const { svg } = await mermaid.render(id, diagram);
      container.innerHTML = svg;
    } catch (e) {
      container.innerHTML = `<p class="texto-dim" style="text-align:center;padding:2rem">
        Error al renderizar diagrama. Revisa la sintaxis Mermaid.
      </p>`;
      console.error('Mermaid render error:', e);
    }
  }

  // === IntersectionObserver para lazy render ===
  function initMermaidObservers() {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            renderMermaid(entry.target as HTMLElement);
            observer.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '200px' }
    );

    document.querySelectorAll('[data-mermaid]').forEach((el) => {
      // Evitar re-observar contenedores ya renderizados
      if (!el.querySelector('svg')) {
        observer.observe(el);
      }
    });
  }

  initMermaidObservers();

  // Re-observar tras cada transición de View Transitions
  document.addEventListener('astro:page-load', initMermaidObservers);
</script>