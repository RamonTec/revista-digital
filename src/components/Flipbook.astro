---
// ============================================================
// Flipbook.astro — Wrapper de StPageFlip (page-flip)
// Renderiza las 12 secciones como hojas de un libro físico
// Arrastre real con mouse/touch, sombras 3D, responsive
// ============================================================

import Portada from '../sections/Portada.astro';
import Editorial from '../sections/Editorial.astro';
import Indice from '../sections/Indice.astro';
import ZonaTech from '../sections/ZonaTech.astro';
import FundamentosBDD from '../sections/FundamentosBDD.astro';
import FundamentosBD from '../sections/FundamentosBD.astro';
import ArquitecturaModelado from '../sections/ArquitecturaModelado.astro';
import Seguridad from '../sections/Seguridad.astro';
import CasoInicio from '../sections/CasoInicio.astro';
import CasoModelado from '../sections/CasoModelado.astro';
import CasoNormalizacion from '../sections/CasoNormalizacion.astro';
import CasoSQLAcople from '../sections/CasoSQLAcople.astro';
import EspacimientoMental from '../sections/EspacimientoMental.astro';
import EquipoEditorial from '../sections/EquipoEditorial.astro';
import Contraportada from '../sections/Contraportada.astro';

import { secciones } from '../data/secciones';
---

<div class="flipbook-app">
  <div class="flipbook-container">
    <div class="page-flip-root" id="book">
      <div class="page-flip-page" data-density="hard">
        <Portada />
      </div>
      <div class="page-flip-page">
        <Editorial />
      </div>
      <div class="page-flip-page">
        <Indice />
      </div>
      <div class="page-flip-page">
        <ZonaTech />
      </div>
      <div class="page-flip-page">
        <FundamentosBDD />
      </div>
      <div class="page-flip-page">
        <FundamentosBD />
      </div>
      <div class="page-flip-page">
        <ArquitecturaModelado />
      </div>
      <div class="page-flip-page">
        <Seguridad />
      </div>
      <div class="page-flip-page">
        <CasoInicio />
      </div>
      <div class="page-flip-page">
        <CasoModelado />
      </div>
      <div class="page-flip-page">
        <CasoNormalizacion />
      </div>
      <div class="page-flip-page">
        <CasoSQLAcople />
      </div>
      <div class="page-flip-page">
        <EspacimientoMental />
      </div>
      <div class="page-flip-page">
        <EquipoEditorial />
      </div>
      <div class="page-flip-page">
        <Contraportada />
      </div>
    </div>
  </div>


  <!-- Controles de navegación -->
  <div class="flip-controls" id="flip-controls">
    <button class="flip-btn" id="flip-prev" type="button" aria-label="Página anterior">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="15 18 9 12 15 6" />
      </svg>
      <span>Anterior</span>
    </button>

    <button class="flip-indice-toggle" id="flip-indice-toggle" type="button" aria-label="Índice">
      Índice
    </button>

    <span class="flip-indicator" id="flip-indicator">
      <strong id="flip-current">1</strong> / {secciones.length}
    </span>

    <button class="flip-btn" id="flip-next" type="button" aria-label="Página siguiente">
      <span>Siguiente</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="9 18 15 12 9 6" />
      </svg>
    </button>
  </div>

  <!-- Botones laterales flotantes -->
  <button class="flip-side-btn flip-side-prev" id="flip-side-prev" aria-label="Página anterior">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6" />
    </svg>
  </button>
  <button class="flip-side-btn flip-side-next" id="flip-side-next" aria-label="Página siguiente">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6" />
    </svg>
  </button>

  <!-- Panel de índice desplegable -->
  <div class="flip-indice-panel" id="flip-indice-panel" role="dialog" aria-label="Índice de la revista">
    <div class="flip-indice-lista" id="flip-indice-lista">
      {secciones.map((s) => (
        <div
          class="flip-indice-item"
          data-page-num={s.pageNum}
          data-slug={s.slug}
          role="button"
          tabindex="0"
          aria-label={`Ir a ${s.titulo}`}
        >
          <span class="flip-indice-item__num texto-acento mono">{s.numero}</span>
          <span class="flip-indice-item__titulo">{s.titulo}</span>
          <span class="flip-indice-item__cat">{s.categoria}</span>
        </div>
      ))}
    </div>
  </div>
</div>

<script>
  import { PageFlip } from 'page-flip';
  import { secciones } from '../data/secciones';

  type PageFlipInstance = InstanceType<typeof PageFlip>;
  let pageFlip: PageFlipInstance | null = null;

  // === Medir espacio real disponible en el DOM ===
  // En móvil: el contenedor flex ocupa toda la pantalla, se miden sus
  // dimensiones reales con getBoundingClientRect.
  // En desktop: se respeta el aspect-ratio landscape del CSS (3/2 o 16/10)
  //   para que PageFlip muestre 2 páginas lado a lado.
  function measureAvailableSpace() {
    const vw = window.innerWidth;
    const vh = window.innerHeight;
    const isMobile = vw <= 768;

    // Medir el contenedor real que ya tiene flex: 1 + min-height: 0
    const container = document.querySelector('.flipbook-container') as HTMLElement | null;
    if (container) {
      const rect = container.getBoundingClientRect();
      const width = Math.floor(rect.width) - 2;
      const height = Math.floor(rect.height) - 2;
      if (width > 0 && height > 0) {
        return { width, height };
      }
    }

    // Fallback si no se pudo medir el contenedor
    if (isMobile) {
      return {
        width: Math.max(vw - 20, 300),
        height: Math.max(vh - 80, 400),
      };
    } else {
      const padding = 32;
      const controlsAndGap = 76;
      return {
        width: Math.max(vw - padding, 300),
        height: Math.max(vh - padding - controlsAndGap, 400),
      };
    }
  }

  function initFlipbook() {
    const bookEl = document.getElementById('book');
    if (!bookEl) return;

    // Guard: no reinicializar si el flipbook ya está activo
    if (pageFlip) {
      // Verificar si la instancia sigue válida (el elemento existe y tiene hijos)
      const hasChildren = bookEl.querySelector('.stf__wrapper') || bookEl.querySelector('canvas');
      if (hasChildren) return;
      // Si no tiene hijos, la instancia quedó huérfana — limpiar
      try { pageFlip.destroy(); } catch {}
      pageFlip = null;
    }

    const { width, height } = measureAvailableSpace();

    pageFlip = new PageFlip(bookEl, {
      width,
      height,
      size: 'stretch',
      minWidth: 300,
      maxWidth: 9999,
      minHeight: 400,
      maxHeight: 9999,
      drawShadow: true,
      flippingTime: 600,
      usePortrait: true,
      startZIndex: 0,
      maxShadowOpacity: 0.4,
      showCover: true,
      showPageCorners: false, // <-- Quita el efecto automático de curvar la hoja al acercar el mouse
      mobileScrollSupport: true,
      swipeDistance: 20,
      clickEventForward: true,
      useMouseEvents: true, // Se requiere true para no romper scroll nativo/mobile interno
      disableFlipByClick: false,
    });

    pageFlip.loadFromHTML(document.querySelectorAll('.page-flip-page'));

    // === Evento: página cambiada ===
    pageFlip.on('flip', (e: { data: number }) => {
      const pageNum = e.data;
      updateIndicator(pageNum);
      updateButtons(pageNum);
      highlightCurrentIndice(pageNum);
      updateProgress(pageNum);

      // Feedback háptico
      if ('vibrate' in navigator) {
        navigator.vibrate(10);
      }

      // Re-inicializar scroll-reveal de la hoja visible
      setTimeout(() => {
        const event = new Event('astro:page-load');
        document.dispatchEvent(event);
      }, 300);
    });

    // === Inicializar controles ===
    initControls();
    initTouchNav();
    initSwipeGestures();
    initIndiceSearch();

    // Estado inicial
    updateIndicator(0);
    updateButtons(0);

    // 1. Evitar el "drag to flip" SOLO con el mouse en desktop (interceptando en fase de captura)
    bookEl.addEventListener('mousedown', (e) => { e.stopPropagation(); }, { capture: true });
    bookEl.addEventListener('mousemove', (e) => { e.stopPropagation(); }, { capture: true });

    // 2. Permitir el scroll nativo con la rueda del mouse a través de la capa interceptora de StPageFlip
    bookEl.addEventListener('wheel', (e) => {
      const block = document.querySelector('.stf__block') as HTMLElement;
      if (block) {
        const oldDisplay = block.style.display;
        block.style.display = 'none'; // Ocultar temporalmente para ver qué hay debajo
        const target = document.elementFromPoint(e.clientX, e.clientY);
        block.style.display = oldDisplay;
        
        if (target) {
          const scrollable = target.closest('.hoja-contenido');
          if (scrollable) {
            scrollable.scrollTop += e.deltaY;
          }
        }
      }
    }, { passive: true });

    // Exponer globalmente para FlipControls o debug
    (window as any).__pageFlip = pageFlip;
  }

  function updateIndicator(pageNum: number) {
    const currentEl = document.getElementById('flip-current');
    if (currentEl) {
      currentEl.textContent = String(pageNum + 1);
    }
  }

  function updateButtons(pageNum: number) {
    const prevBtn = document.getElementById('flip-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('flip-next') as HTMLButtonElement | null;
    const touchPrev = document.getElementById('flip-touch-prev') as HTMLButtonElement | null;
    const touchNext = document.getElementById('flip-touch-next') as HTMLButtonElement | null;
    const sidePrev = document.getElementById('flip-side-prev') as HTMLButtonElement | null;
    const sideNext = document.getElementById('flip-side-next') as HTMLButtonElement | null;
    const total = secciones.length;

    if (prevBtn) prevBtn.disabled = pageNum === 0;
    if (nextBtn) nextBtn.disabled = pageNum === total - 1;
    if (touchPrev) touchPrev.disabled = pageNum === 0;
    if (touchNext) touchNext.disabled = pageNum === total - 1;
    if (sidePrev) sidePrev.disabled = pageNum === 0;
    if (sideNext) sideNext.disabled = pageNum === total - 1;
  }

  function updateProgress(pageNum: number) {
    const fill = document.getElementById('progress-fill');
    if (fill) {
      const progress = ((pageNum + 1) / secciones.length) * 100;
      fill.style.width = `${progress}%`;
    }
  }

  function highlightCurrentIndice(pageNum: number) {
    document.querySelectorAll('.flip-indice-item').forEach((el) => {
      const num = parseInt(el.getAttribute('data-page-num') || '-1', 10);
      el.classList.toggle('actual', num === pageNum);
    });
  }

  function initControls() {
    const prevBtn = document.getElementById('flip-prev');
    const nextBtn = document.getElementById('flip-next');
    const sidePrev = document.getElementById('flip-side-prev');
    const sideNext = document.getElementById('flip-side-next');
    const indiceToggle = document.getElementById('flip-indice-toggle');
    const indicePanel = document.getElementById('flip-indice-panel');
    const indiceOverlay = document.getElementById('flip-indice-overlay');
    const indiceClose = document.getElementById('flip-indice-close');
    const indiceItems = document.querySelectorAll('.flip-indice-item');

    // Botones anterior/siguiente
    const goPrev = () => pageFlip?.flipPrev('top');
    const goNext = () => pageFlip?.flipNext('top');

    prevBtn?.addEventListener('click', goPrev);
    nextBtn?.addEventListener('click', goNext);
    sidePrev?.addEventListener('click', goPrev);
    sideNext?.addEventListener('click', goNext);

    // Índice: abrir/cerrar
    function abrirIndice() {
      indicePanel?.classList.add('visible');
      indiceOverlay?.classList.add('visible');
      indiceToggle?.classList.add('activa');
    }

    function cerrarIndice() {
      indicePanel?.classList.remove('visible');
      indiceOverlay?.classList.remove('visible');
      indiceToggle?.classList.remove('activa');
    }

    indiceToggle?.addEventListener('click', abrirIndice);
    indiceClose?.addEventListener('click', cerrarIndice);
    indiceOverlay?.addEventListener('click', cerrarIndice);

    // Items del índice: saltar a página
    indiceItems.forEach((item) => {
      const pageNum = parseInt(item.getAttribute('data-page-num') || '0', 10);
      const goToPage = () => {
        pageFlip?.flip(pageNum, 'top');
        cerrarIndice();
      };
      item.addEventListener('click', goToPage);
      item.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          goToPage();
        }
      });
    });

    // Teclado: flechas izq/derecha
    document.addEventListener('keydown', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName === 'INPUT' || target.tagName === 'TEXTAREA') return;
      if (e.altKey || e.ctrlKey || e.metaKey) return;

      if (e.key === 'ArrowRight') {
        e.preventDefault();
        pageFlip?.flipNext('top');
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        pageFlip?.flipPrev('top');
      } else if (e.key === 'Escape') {
        cerrarIndice();
      }
    });
  }

  // === Botones de navegación táctiles flotantes ===
  function initTouchNav() {
    const touchPrev = document.getElementById('flip-touch-prev');
    const touchNext = document.getElementById('flip-touch-next');

    touchPrev?.addEventListener('click', () => {
      pageFlip?.flipPrev('top');
    });

    touchNext?.addEventListener('click', () => {
      pageFlip?.flipNext('top');
    });
  }

  // === Gestos táctiles: swipe horizontal ===
  // Refuerza el swipe nativo de StPageFlip en zonas donde el scroll
  // vertical del contenido puede interferir.
  function initSwipeGestures() {
    let touchStartX = 0;
    let touchStartY = 0;
    const SWIPE_THRESHOLD = 50;
    const SWIPE_VERTICAL_TOLERANCE = 80;

    const bookEl = document.getElementById('book');
    if (!bookEl) return;

    bookEl.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.changedTouches[0].screenX;
      touchStartY = e.changedTouches[0].screenY;
    }, { passive: true });

    bookEl.addEventListener('touchend', (e: TouchEvent) => {
      const touchEndX = e.changedTouches[0].screenX;
      const touchEndY = e.changedTouches[0].screenY;
      const diffX = touchStartX - touchEndX;
      const diffY = touchStartY - touchEndY;

      // Ignorar si el movimiento fue principalmente vertical (scroll de contenido)
      if (Math.abs(diffY) > SWIPE_VERTICAL_TOLERANCE) return;

      if (diffX > SWIPE_THRESHOLD) {
        pageFlip?.flipNext('top');
      } else if (diffX < -SWIPE_THRESHOLD) {
        pageFlip?.flipPrev('top');
      }
    }, { passive: true });
  }

  // === Buscador del índice ===
  function initIndiceSearch() {
    const searchInput = document.getElementById('flip-indice-search');
    const indiceItems = document.querySelectorAll('.flip-indice-item');

    searchInput?.addEventListener('input', (e) => {
      const term = (e.target as HTMLInputElement).value.toLowerCase().trim();

      indiceItems.forEach((item) => {
        const text = (item.textContent || '').toLowerCase();
        (item as HTMLElement).style.display = text.includes(term) ? '' : 'none';
      });
    });
  }

  // === Auto-init ===
  // Usar requestAnimationFrame para asegurar que el layout del DOM esté
  // completamente renderizado antes de medir el contenedor con getBoundingClientRect.
  function bootstrap() {
    requestAnimationFrame(() => {
      requestAnimationFrame(initFlipbook);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootstrap);
  } else {
    bootstrap();
  }

  // === Resize handler: recalcular dimensiones al rotar/redimensionar ===
  let resizeTimer: number | null = null;
  function recalcularDimensiones() {
    if (!pageFlip) return;
    const { width, height } = measureAvailableSpace();
    try {
      pageFlip.updateState({ width, height });
    } catch {
      const bookEl = document.getElementById('book');
      if (bookEl) {
        try {
          pageFlip.destroy();
        } catch {}
        pageFlip = null;
        initFlipbook();
      }
    }
  }

  window.addEventListener('resize', () => {
    if (resizeTimer) clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(recalcularDimensiones, 200);
  });

  // Recalcular al cambiar orientación en móvil
  window.addEventListener('orientationchange', () => {
    if (resizeTimer) clearTimeout(resizeTimer);
    resizeTimer = window.setTimeout(recalcularDimensiones, 300);
  });

  // Nota: NO escuchar astro:page-load aquí.
  // FlipLayout no usa ClientRouter, por lo que ese evento nunca debería dispararse.
  // Si se dispara (por residual del redirect), causaría doble-init y parpadeo.
</script>