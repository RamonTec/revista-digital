---
// ============================================================
// SectionHeader.astro — Cabecera de sección editorial
// Número grande + título + descripción + línea decorativa
// ============================================================

export interface Props {
  numero: string;
  titulo: string;
  descripcion?: string;
  categoria?: string;
}

const { numero, titulo, descripcion = '', categoria = '' } = Astro.props;

const categoriaLabels: Record<string, string> = {
  apertura: 'Apertura',
  teoria: 'Teoría',
  practica: 'Caso Práctico',
  cierre: 'Cierre',
};
---

<header class="section-header" data-reveal>
  <div class="section-header__top">
    <span class="section-header__num mono">{numero}</span>
    {categoria && (
      <span class="section-header__cat">{categoriaLabels[categoria] || categoria}</span>
    )}
  </div>

  <h1 class="section-header__titulo">{titulo}</h1>

  {descripcion && (
    <p class="section-header__desc texto-dim">{descripcion}</p>
  )}

  <div class="section-header__linea"></div>
</header>

<style>
  .section-header {
    margin-bottom: var(--sp-7);
    padding-bottom: var(--sp-5);
  }

  .section-header__top {
    display: flex;
    align-items: baseline;
    gap: var(--sp-4);
    margin-bottom: var(--sp-3);
  }

  .section-header__num {
    font-size: var(--fs-2xl);
    font-weight: var(--fw-black);
    color: var(--c-acento);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .section-header__cat {
    font-size: var(--fs-xs);
    font-weight: var(--fw-semibold);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--c-texto-muted);
    padding: var(--sp-1) var(--sp-3);
    border: 1px solid var(--c-borde);
    border-radius: var(--r-full);
  }

  .section-header__titulo {
    font-size: var(--fs-3xl);
    font-weight: var(--fw-black);
    line-height: var(--lh-tight);
    margin-bottom: var(--sp-3);
    letter-spacing: -0.03em;
  }

  .section-header__desc {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    max-width: var(--content-max);
  }

  .section-header__linea {
    height: 3px;
    width: 60px;
    background: linear-gradient(
      90deg,
      var(--c-acento),
      var(--c-acento-alt)
    );
    border-radius: var(--r-full);
    margin-top: var(--sp-5);
  }

  @media (max-width: 639px) {
    .section-header__titulo {
      font-size: var(--fs-2xl);
    }

    .section-header__num {
      font-size: var(--fs-xl);
    }
  }
</style>