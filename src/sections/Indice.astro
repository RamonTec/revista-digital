---
// ============================================================
// Indice.astro — Índice navegable de la edición
// Click en una sección → salta a la hoja del flipbook
// (o navega a la página estática si no hay flipbook)
// ============================================================

import SectionHeader from '../components/SectionHeader.astro';
import { secciones } from '../data/secciones';

const categorias = [
  { id: 'apertura', label: 'Apertura', icono: '◈' },
  { id: 'teoria', label: 'Teoría', icono: '◆' },
  { id: 'practica', label: 'Caso Práctico', icono: '▶' },
  { id: 'cierre', label: 'Cierre', icono: '◉' },
] as const;
---

<div class="hoja-contenido">
  <SectionHeader
    numero="02"
    titulo="Índice"
    descripcion="Mapa de navegación de la edición"
    categoria="apertura"
  />

  <section class="indice">
    {categorias.map((cat, catIdx) => (
      <div class="indice-categoria" data-reveal data-reveal-delay={String(catIdx + 1)}>
        <h2 class="indice-categoria__label">
          <span class="indice-categoria__icono">{cat.icono}</span>
          {cat.label}
        </h2>

        <ol class="indice-lista">
          {secciones
            .filter((s) => s.categoria === cat.id)
            .map((s) => (
              <li class="indice-item">
                <a href={s.href} class="indice-item__enlace" data-page-num={s.pageNum}>
                  <span class="indice-item__num mono texto-acento">{s.numero}</span>
                  <div class="indice-item__info">
                    <span class="indice-item__titulo">{s.titulo}</span>
                    <span class="indice-item__desc texto-dim">{s.descripcion}</span>
                  </div>
                  <svg
                    class="indice-item__flecha"
                    width="18" height="18"
                    viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2"
                  >
                    <polyline points="9 18 15 12 9 6" />
                  </svg>
                </a>
              </li>
            ))}
        </ol>
      </div>
    ))}
  </section>
</div>

<script>
  // === Intercepta clicks del índice si estamos en el flipbook ===
  // En modo flipbook: salta a la hoja con pageFlip.flip(pageNum)
  // En modo estático: navegación normal (el enlace hace su trabajo)
  function initIndiceFlipbookLinks() {
    const enlaces = document.querySelectorAll('.indice-item__enlace[data-page-num]');
    if (!enlaces.length) return;

    enlaces.forEach((enlace) => {
      enlace.addEventListener('click', (e) => {
        const pageFlip = (window as any).__pageFlip;
        if (!pageFlip) return; // modo estático: navegación normal

        const pageNum = parseInt(
          (enlace as HTMLElement).dataset.pageNum || '0',
          10
        );

        e.preventDefault();
        pageFlip.flip(pageNum, 'top');
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initIndiceFlipbookLinks);
  } else {
    initIndiceFlipbookLinks();
  }

  document.addEventListener('astro:page-load', initIndiceFlipbookLinks);
</script>

<style>
  /* === Estilos base: tamaños cómodos (portrait/móvil con scroll funcional) === */
  .indice {
    margin-top: var(--sp-5);
  }

  .indice-categoria {
    margin-bottom: var(--sp-5);
  }

  .indice-categoria__label {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-lg);
    color: var(--c-acento-alt);
    margin-bottom: var(--sp-3);
    padding-bottom: var(--sp-2);
    border-bottom: 1px solid var(--c-borde);
  }

  .indice-categoria__icono {
    color: var(--c-acento);
    font-size: var(--fs-md);
  }

  .indice-lista {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .indice-item__enlace {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-3) var(--sp-4);
    border: 1px solid var(--c-borde);
    border-radius: var(--r-md);
    text-decoration: none;
    color: var(--c-texto);
    transition: all var(--t-fast);
    cursor: pointer;
  }

  .indice-item__enlace:hover {
    border-color: var(--c-acento);
    background: var(--c-bg-secundario);
    transform: translateX(4px);
  }

  .indice-item__num {
    font-size: var(--fs-md);
    font-weight: var(--fw-bold);
    min-width: 36px;
    text-align: center;
  }

  .indice-item__info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .indice-item__titulo {
    font-weight: var(--fw-medium);
    font-size: var(--fs-base);
  }

  .indice-item__desc {
    font-size: var(--fs-sm);
  }

  .indice-item__flecha {
    color: var(--c-texto-muted);
    transition: transform var(--t-fast);
    flex-shrink: 0;
  }

  .indice-item__enlace:hover .indice-item__flecha {
    transform: translateX(4px);
    color: var(--c-acento);
  }

  /* === Landscape desktop (≥769px): grid de 2 columnas + tamaños legibles === */
  /* El grid de 2 columnas aprovecha el ancho horizontal del landscape, */
  /* reduciendo la altura total del índice y minimizando la necesidad de scroll. */
  /* El scroll de .hoja-contenido está habilitado en flipbook.css como respaldo. */
  @media (min-width: 769px) {
    .indice {
      margin-top: var(--sp-4);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0 var(--sp-5);
      align-items: start;
    }

    .indice-categoria {
      margin-bottom: var(--sp-4);
    }

    .indice-categoria__label {
      font-size: var(--fs-md);
      margin-bottom: var(--sp-2);
      padding-bottom: var(--sp-1);
    }

    .indice-lista {
      gap: var(--sp-2);
    }

    .indice-item__enlace {
      padding: var(--sp-2) var(--sp-3);
    }

    .indice-item__titulo {
      font-size: var(--fs-sm);
    }

    .indice-item__desc {
      font-size: var(--fs-xs);
    }
  }

  /* === Desktop grande (≥1024px): mantener 2 columnas con más respiro === */
  @media (min-width: 1024px) {
    .indice {
      gap: 0 var(--sp-6);
    }
  }

  /* === Móvil pequeño (≤639px): ocultar descripciones === */
  @media (max-width: 639px) {
    .indice-item__desc {
      display: none;
    }
  }
</style>