---
// index.astro — Portada de la revista
// Diseño editorial con parallax, tipografía display y CTA
import { revista, secciones } from '../data/secciones';
const seccionesDestacadas = secciones.filter(
  (s) => s.categoria === 'teoria' || s.categoria === 'practica'
);
---

<div class="hoja-contenido">
<!-- === Hero portada === -->
  <section class="portada-hero">
    <div class="portada-hero__fondo" data-parallax="0.15"></div>

    <div class="portada-hero__contenido">
      <span class="portada-hero__edicion mono texto-acento" data-reveal="fade">
        {revista.edicion} — {revista.fecha}
      </span>

      <h1 class="portada-hero__titulo" data-reveal data-reveal-delay="1">
        <span class="portada-hero__marca">BDD</span>
        <span class="portada-hero__sub">Revista Digital</span>
      </h1>

      <p class="portada-hero__lema texto-dim" data-reveal data-reveal-delay="2">
        {revista.lema}
      </p>

      <p class="portada-hero__subtitulo texto-dim" data-reveal data-reveal-delay="3">
        {revista.subtitulo}
      </p>

      <a
        href="/editorial-indice"
        class="portada-hero__cta"
        data-reveal data-reveal-delay="4"
      >
        Comenzar a leer
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>

    <div class="portada-hero__scroll scroll-indicador" aria-hidden="true"></div>
  </section>

  <!-- === Secciones destacadas === -->
  <section class="portada-destacadas">
    <h2 class="portada-destacadas__titulo" data-reveal>
      En esta edición
    </h2>

    <div class="portada-destacadas__grid">
      {seccionesDestacadas.map((s, i) => (
        <a
          href={s.href}
          class="tarjeta portada-card"
          data-reveal={i % 2 === 0 ? 'left' : 'right'}
          data-reveal-delay={String((i % 3) + 1)}
        >
          <span class="portada-card__num mono texto-acento">{s.numero}</span>
          <h3 class="portada-card__titulo">{s.titulo}</h3>
          <p class="portada-card__desc texto-dim">{s.descripcion}</p>
          <span class="portada-card__categoria">{s.categoria}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- === Stats / metadatos === -->
  <section class="portada-meta" data-reveal>
    <div class="portada-meta__item">
      <span class="portada-meta__num mono texto-acento">12</span>
      <span class="portada-meta__label texto-dim">Secciones</span>
    </div>
    <div class="portada-meta__item">
      <span class="portada-meta__num mono texto-acento">04</span>
      <span class="portada-meta__label texto-dim">Diagramas</span>
    </div>
    <div class="portada-meta__item">
      <span class="portada-meta__num mono texto-acento">15+</span>
      <span class="portada-meta__label texto-dim">Snippets SQL</span>
    </div>
    <div class="portada-meta__item">
      <span class="portada-meta__num mono texto-acento">01</span>
      <span class="portada-meta__label texto-dim">Caso práctico</span>
    </div>
  </section>
</div>

<style>
  /* === Hero === */
  .portada-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: var(--sp-7) 0;
    overflow: hidden;
  }

  .portada-hero__fondo {
    position: absolute;
    inset: -20%;
    background:
      radial-gradient(ellipse at 20% 30%, rgba(0, 217, 163, 0.12), transparent 50%),
      radial-gradient(ellipse at 80% 70%, rgba(77, 158, 255, 0.1), transparent 50%),
      linear-gradient(180deg, transparent, var(--c-bg-primario) 90%);
    z-index: -1;
  }

  .portada-hero__contenido {
    max-width: var(--content-wide);
  }

  .portada-hero__edicion {
    display: inline-block;
    font-size: var(--fs-sm);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--sp-4);
    padding: var(--sp-1) var(--sp-3);
    border: 1px solid var(--c-acento);
    border-radius: var(--r-full);
  }

  .portada-hero__titulo {
    font-size: var(--fs-display);
    font-weight: var(--fw-black);
    line-height: 0.95;
    letter-spacing: -0.05em;
    margin-bottom: var(--sp-5);
  }

  .portada-hero__marca {
    display: block;
    color: var(--c-acento);
    font-size: 1.4em;
  }

  .portada-hero__sub {
    display: block;
    font-size: 0.5em;
    font-weight: var(--fw-light);
    color: var(--c-texto);
    letter-spacing: -0.02em;
  }

  .portada-hero__lema {
    font-size: var(--fs-xl);
    font-style: italic;
    max-width: 600px;
    margin-bottom: var(--sp-3);
  }

  .portada-hero__subtitulo {
    font-size: var(--fs-lg);
    margin-bottom: var(--sp-6);
  }

  .portada-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-6);
    background: var(--c-acento);
    color: var(--c-bg-primario);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-md);
    border-radius: var(--r-full);
    transition: all var(--t-normal);
    box-shadow: var(--shadow-glow);
  }

  .portada-hero__cta:hover {
    background: var(--c-acento-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg), var(--shadow-glow);
  }

  .portada-hero__scroll {
    position: absolute;
    bottom: var(--sp-5);
    left: 50%;
    transform: translateX(-50%);
  }

  /* === Secciones destacadas === */
  .portada-destacadas {
    margin-top: var(--sp-9);
    padding-top: var(--sp-7);
    border-top: 1px solid var(--c-borde);
  }

  .portada-destacadas__titulo {
    font-size: var(--fs-2xl);
    margin-bottom: var(--sp-6);
  }

  .portada-destacadas__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-4);
  }

  @media (min-width: 768px) {
    .portada-destacadas__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .portada-destacadas__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .portada-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-5);
    background: var(--c-bg-secundario);
    border: 1px solid var(--c-borde);
    border-radius: var(--r-md);
    text-decoration: none;
    color: var(--c-texto);
  }

  .portada-card__num {
    font-size: var(--fs-xl);
    font-weight: var(--fw-black);
  }

  .portada-card__titulo {
    font-size: var(--fs-lg);
    font-weight: var(--fw-semibold);
  }

  .portada-card__desc {
    font-size: var(--fs-sm);
    flex: 1;
  }

  .portada-card__categoria {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-texto-muted);
    padding-top: var(--sp-2);
    border-top: 1px solid var(--c-borde);
  }

  /* === Stats === */
  .portada-meta {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-4);
    margin-top: var(--sp-8);
    padding: var(--sp-6);
    background: var(--c-bg-secundario);
    border: 1px solid var(--c-borde);
    border-radius: var(--r-md);
  }

  @media (min-width: 768px) {
    .portada-meta {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .portada-meta__item {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .portada-meta__num {
    font-size: var(--fs-2xl);
    font-weight: var(--fw-black);
  }

  .portada-meta__label {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* === Móvil === */
  @media (max-width: 639px) {
    .portada-hero__titulo {
      font-size: var(--fs-4xl);
    }

    .portada-hero__lema {
      font-size: var(--fs-md);
    }

    .portada-hero__subtitulo {
      font-size: var(--fs-base);
    }
  }
</style>
