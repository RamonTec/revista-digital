---
// ============================================================
// Portada.astro — Portada de la revista (solo hero + CTA)
// Sin "En esta edición", sin tarjetas, sin stats
// ============================================================

import { revista } from '../data/secciones';
---

<div class="hoja-contenido">
  <section class="portada-hero">
    <div class="portada-hero__fondo" data-parallax="0.15"></div>

    <div class="portada-hero__contenido">
      <span class="portada-hero__edicion mono texto-acento" data-reveal="fade">
        {revista.edicion} — {revista.fecha}
      </span>

      <h1 class="portada-hero__titulo" data-reveal data-reveal-delay="1">
        <span class="portada-hero__marca">BDD</span>
        <span class="portada-hero__sub">Revista Digital</span>
      </h1>

      <p class="portada-hero__lema texto-dim" data-reveal data-reveal-delay="2">
        {revista.lema}
      </p>

      <p class="portada-hero__subtitulo texto-dim" data-reveal data-reveal-delay="3">
        {revista.subtitulo}
      </p>

      <button
        class="portada-hero__cta"
        data-reveal data-reveal-delay="4"
        id="portada-cta"
        type="button"
      >
        Comenzar a leer
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </button>
    </div>

    <div class="portada-hero__scroll scroll-indicador" aria-hidden="true"></div>
  </section>
</div>

<script>
  // === CTA: avanzar a la hoja 1 (Editorial) dentro del flipbook ===
  // Si no hay flipbook (modo estático), navegar a /editorial-indice
  function initPortadaCTA() {
    const cta = document.getElementById('portada-cta');
    if (!cta) return;

    cta.addEventListener('click', () => {
      const pageFlip = (window as any).__pageFlip;
      if (pageFlip) {
        pageFlip.flipNext('top');
      } else {
        window.location.href = '/editorial-indice';
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPortadaCTA);
  } else {
    initPortadaCTA();
  }
</script>

<style>
  .portada-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: var(--sp-7) 0;
    overflow: hidden;
  }

  .portada-hero__fondo {
    position: absolute;
    inset: -20%;
    background:
      radial-gradient(ellipse at 20% 30%, rgba(0, 217, 163, 0.12), transparent 50%),
      radial-gradient(ellipse at 80% 70%, rgba(77, 158, 255, 0.1), transparent 50%),
      linear-gradient(180deg, transparent, var(--c-bg-primario) 90%);
    z-index: -1;
  }

  .portada-hero__contenido {
    max-width: var(--content-wide);
  }

  .portada-hero__edicion {
    display: inline-block;
    font-size: var(--fs-sm);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--sp-4);
    padding: var(--sp-1) var(--sp-3);
    border: 1px solid var(--c-acento);
    border-radius: var(--r-full);
  }

  .portada-hero__titulo {
    font-size: var(--fs-display);
    font-weight: var(--fw-black);
    line-height: 0.95;
    letter-spacing: -0.05em;
    margin-bottom: var(--sp-5);
  }

  .portada-hero__marca {
    display: block;
    color: var(--c-acento);
    font-size: 1.4em;
  }

  .portada-hero__sub {
    display: block;
    font-size: 0.5em;
    font-weight: var(--fw-light);
    color: var(--c-texto);
    letter-spacing: -0.02em;
  }

  .portada-hero__lema {
    font-size: var(--fs-xl);
    font-style: italic;
    max-width: 600px;
    margin-bottom: var(--sp-3);
  }

  .portada-hero__subtitulo {
    font-size: var(--fs-lg);
    margin-bottom: var(--sp-6);
  }

  .portada-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-6);
    background: var(--c-acento);
    color: var(--c-bg-primario);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-md);
    border: none;
    border-radius: var(--r-full);
    cursor: pointer;
    transition: all var(--t-normal);
    box-shadow: var(--shadow-glow);
  }

  .portada-hero__cta:hover {
    background: var(--c-acento-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg), var(--shadow-glow);
  }

  .portada-hero__scroll {
    position: absolute;
    bottom: var(--sp-5);
    left: 50%;
    transform: translateX(-50%);
  }

  @media (max-width: 639px) {
    .portada-hero__titulo {
      font-size: var(--fs-4xl);
    }

    .portada-hero__lema {
      font-size: var(--fs-md);
    }

    .portada-hero__subtitulo {
      font-size: var(--fs-base);
    }
  }
</style>