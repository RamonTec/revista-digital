---
// seguridad.astro — Seguridad en bases de datos
import SectionHeader from '../components/SectionHeader.astro';
import CodeBlock from '../components/CodeBlock.astro';
import Callout from '../components/Callout.astro';
---

<div class="hoja-contenido">
<SectionHeader
    numero="07"
    titulo="Seguridad"
    descripcion="Protegiendo el dato: buenas prácticas de seguridad en bases de datos"
    categoria="teoria"
  />

  <!-- === Principios === -->
  <section data-reveal>
    <h2>Los tres pilares de la seguridad de datos</h2>

    <div class="grid-3-col">
      <div class="pilar tarjeta">
        <span class="pilar__icono texto-acento">CIA</span>
        <h3>Confidencialidad</h3>
        <p>Solo quien debe acceder, accede. Control de acceso por roles, cifrado en tránsito y en reposo.</p>
      </div>
      <div class="pilar tarjeta">
        <span class="pilar__icono texto-acento">↓</span>
        <h3>Integridad</h3>
        <p>El dato no se altera sin autorización. Constraints, foreign keys, transacciones ACID.</p>
      </div>
      <div class="pilar tarjeta">
        <span class="pilar__icono texto-acento">↑</span>
        <h3>Disponibilidad</h3>
        <p>El dato está cuando se necesita. Backups, replicación, alta disponibilidad.</p>
      </div>
    </div>

    <Callout tipo="warn" titulo="Triada CIA">
      <p>
        Todo diseño de seguridad parte de la <strong>triada CIA</strong>
        (Confidentiality, Integrity, Availability). Toda decisión técnica
        debe evaluar su impacto en al menos uno de estos tres pilares.
      </p>
    </Callout>
  </section>

  <hr />

  <!-- === Inyección SQL === -->
  <section data-reveal>
    <h2>Inyección SQL: el ataque más antiguo y aún vigente</h2>

    <p>
      La <strong>inyección SQL</strong> (SQLi) es una vulnerabilidad donde
      un atacante inserta código SQL malicioso en una consulta mediante
      entradas no sanitizadas. Sigue en el <em>top 3</em> de OWASP a pesar
      de ser bien conocida.
    </p>

    <div class="vector-hero" data-reveal>
      <svg class="vector-hero__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        <path d="M9 12l2 2 4-4"></path>
      </svg>
    </div>

    <h3>Ejemplo: consulta vulnerable</h3>

    <CodeBlock
      language="sql"
      filename="vulnerable.sql"
      code={"-- Consulta construida por concatenación de strings (¡PELIGROSO!)\n-- Código de aplicación: input del usuario insertado directamente\nSELECT * FROM socios\nWHERE email = '\" + input_usuario + \"';"}
    />

    <Callout tipo="error" titulo="Ataque típico">
      <p>
        Si <code>input_usuario</code> es <code>' OR '1'='1' --</code>, la
        consulta resultante devuelve <strong>todas las filas</strong> de la
        tabla socios. Peor aún: <code>'; DROP TABLE socios; --</code>
        puede destruir datos.
      </p>
    </Callout>

    <h3>Solución: consultas parametrizadas</h3>

    <CodeBlock
      language="sql"
      filename="seguro.sql"
      code={`-- Consulta parametrizada (SEGURO)
-- El SGBD trata el parámetro como dato, nunca como código
SELECT * FROM socios
WHERE email = :email_param;

-- En Python (psycopg2 / psycopg3):
-- cursor.execute("SELECT * FROM socios WHERE email = %s", (email,))

-- En Java (JDBC PreparedStatement):
-- PreparedStatement ps = conn.prepareStatement(
--     "SELECT * FROM socios WHERE email = ?"
-- );
-- ps.setString(1, email);

-- En Node.js (pg):
-- client.query('SELECT * FROM socios WHERE email = $1', [email])`}
    />

    <Callout tipo="success" titulo="Regla absoluta">
      <p>
        <strong>Nunca</strong> concatenes input del usuario en una consulta
        SQL. Usa <em>siempre</em> consultas parametrizadas o un ORM que las
        use por defecto. No hay excepciones.
      </p>
    </Callout>
  </section>

  <hr />

  <!-- === Principio de menor privilegio === -->
  <section data-reveal>
    <h2>Principio de menor privilegio (PoLP)</h2>

    <p>
      Cada usuario/rol de la base de datos debe tener <strong>solo los
      permisos mínimos</strong> necesarios para su función. La aplicación
      web no necesita <code>DROP</code>, el reporte no necesita
      <code>INSERT</code>.
    </p>

    <CodeBlock
      language="sql"
      filename="roles_seguros.sql"
      code={`-- === Crear roles con privilegios mínimos ===

-- Rol para la aplicación web: solo SELECT e INSERT en socios
CREATE ROLE app_web;
GRANT SELECT, INSERT ON socios TO app_web;
GRANT SELECT, INSERT ON prestamos TO app_web;
GRANT USAGE, SELECT ON SEQUENCE socios_id_seq TO app_web;

-- Rol para reportes: solo SELECT en todas las tablas
CREATE ROLE reportes;
GRANT SELECT ON ALL TABLES IN SCHEMA public TO reportes;

-- Rol de administración: todo, pero solo desde IPs internas
CREATE ROLE admin_db;
GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO admin_db;

-- Revocar privilegios peligrosos al rol público
REVOKE ALL ON SCHEMA public FROM PUBLIC;
GRANT USAGE ON SCHEMA public TO app_web, reportes;

-- Aplicar a un usuario concreto
CREATE USER app_user WITH PASSWORD 'hash_seguro_generado_por_secreto';
GRANT app_web TO app_user;`}
    />
  </section>

  <hr />

  <!-- === Hash de contraseñas === -->
  <section data-reveal>
    <h2>Almacenamiento de contraseñas: hash, no cifrado</h2>

    <p>
      Las contraseñas <strong>nunca</strong> deben almacenarse en texto
      plano ni cifradas de forma reversible. Deben guardarse como
      <em>hash</em> con un algoritmo diseñado para ser costoso:
      <code>bcrypt</code>, <code>argon2</code> o <code>scrypt</code>.
    </p>

    <CodeBlock
      language="sql"
      filename="schema_usuarios.sql"
      code={`CREATE TABLE usuarios (
  id          SERIAL PRIMARY KEY,
  email       VARCHAR(255) UNIQUE NOT NULL,
  password_hash  VARCHAR(255) NOT NULL,  -- bcrypt hash, nunca texto plano
  password_salt  VARCHAR(255) NOT NULL,  -- salt único por usuario
  fallos_login   INT DEFAULT 0,
  bloqueado      BOOLEAN DEFAULT FALSE,
  ultimo_acceso  TIMESTAMP,
  creado_en      TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Nunca hagas esto:
-- INSERT INTO usuarios (password) VALUES ('miPassword123');

-- Haz esto (en la aplicación, no en SQL):
-- hash = bcrypt(password + salt, rounds=12)
-- INSERT INTO usuarios (email, password_hash, password_salt)
-- VALUES ('ana@dev.com', hash, salt);`}
    />

    <Callout tipo="error" titulo="MD5 y SHA-256 no sirven">
      <p>
        <code>MD5</code> y <code>SHA-256</code> son funciones de hash
        <em>rápidas</em>, diseñadas para integridad, no para contraseñas.
        Un atacante con GPU puede probar miles de millones por segundo.
        Usa <code>bcrypt</code> o <code>argon2</code>.
      </p>
    </Callout>
  </section>

  <hr />

  <!-- === Checklist === -->
  <section data-reveal>
    <h2>Checklist de seguridad para producción</h2>

    <div class="checklist">
      <label class="check-item"><input type="checkbox" /> Consultas parametrizadas en todo el código</label>
      <label class="check-item"><input type="checkbox" /> Roles con privilegios mínimos por aplicación</label>
      <label class="check-item"><input type="checkbox" /> Contraseñas con bcrypt/argon2, nunca texto plano</label>
      <label class="check-item"><input type="checkbox" /> Conexión cifrada (TLS/SSL) entre app y base</label>
      <label class="check-item"><input type="checkbox" /> Backups automáticos encriptados y testeados</label>
      <label class="check-item"><input type="checkbox" /> Auditoría de accesos (log de conexiones)</label>
      <label class="check-item"><input type="checkbox" /> Rate limiting en endpoints de autenticación</label>
      <label class="check-item"><input type="checkbox" /> Secrets gestionados (no hardcodeados en código)</label>
      <label class="check-item"><input type="checkbox" /> Actualizaciones del SGBD al día</label>
      <label class="check-item"><input type="checkbox" /> Cifrado de datos sensibles en reposo</label>
    </div>
  </section>

  
</div>

<style>
  h2 {
    font-size: var(--fs-2xl);
    margin-bottom: var(--sp-4);
  }

  h3 {
    font-size: var(--fs-lg);
    margin: var(--sp-5) 0 var(--sp-3);
  }

  p {
    font-size: var(--fs-md);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--sp-4);
  }

  .pilar {
    padding: var(--sp-5);
    background: var(--c-bg-secundario);
    border: 1px solid var(--c-borde);
    border-radius: var(--r-md);
    text-align: center;
  }

  .pilar__icono {
    display: block;
    font-size: var(--fs-2xl);
    font-weight: var(--fw-black);
    font-family: var(--font-mono);
    margin-bottom: var(--sp-2);
  }

  .pilar h3 {
    margin: 0 0 var(--sp-2) 0;
  }

  .pilar p {
    font-size: var(--fs-sm);
    margin: 0;
  }

  .checklist {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin: var(--sp-5) 0;
  }

  .check-item {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3) var(--sp-4);
    background: var(--c-bg-secundario);
    border: 1px solid var(--c-borde);
    border-radius: var(--r-sm);
    font-size: var(--fs-sm);
    cursor: pointer;
    transition: all var(--t-fast);
  }

  .check-item:hover {
    border-color: var(--c-acento);
  }

  .check-item input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: var(--c-acento);
    cursor: pointer;
  }

  .vector-hero {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: var(--sp-5);
    margin: var(--sp-5) 0;
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.05), rgba(244, 63, 94, 0.05));
    border: 1px solid var(--c-borde);
    border-radius: var(--r-lg);
    position: relative;
    overflow: hidden;
  }
  
  .vector-hero::before {
    content: '';
    position: absolute;
    width: 120px;
    height: 120px;
    background: var(--c-acento);
    filter: blur(60px);
    opacity: 0.15;
    border-radius: 50%;
  }

  .vector-hero__icon {
    width: 64px;
    height: 64px;
    color: var(--c-acento);
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 0 12px rgba(99, 102, 241, 0.4));
    transition: transform var(--t-normal);
  }

  .vector-hero:hover .vector-hero__icon {
    transform: scale(1.1) rotate(-2deg);
  }
</style>
